# Groq Desktop Environment Configuration
# Copy this file to .env and add your actual API key
# OR set these environment variables directly

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Optional: Default model for autocomplete (defaults to llama-3.1-8b-instant)
# GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# Anthropic API Configuration (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Configuration (for ChatGPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Instructions:
# 1. Copy this file to .env in the same directory
# 2. Replace the API key placeholders with your actual keys
# 3. Get your Groq API key from: https://console.groq.com/keys
# 4. Get your Anthropic API key from: https://console.anthropic.com
# 5. Get your OpenAI API key from: https://platform.openai.com